<!-- views/partials/bookings/car_rental_form.ejs -->
<form action="/booking" method="POST">
	<% const rentalInput = bookingInput?.service_type === 'car_rental' ? bookingInput : {}; %>
	<%
		const officeAddressParts = [
			businessAddress.streetAddress,
			businessAddress.addressLocality,
			businessAddress.addressRegion,
			businessAddress.postalCode || businessAddress.addressCountry,
		].filter(Boolean);
		const officeAddress = officeAddressParts.join(', ');
	%>
	<div class="row g-3">
		<div class="col-md-6">
			<input type="hidden" name="serviceType" value="car_rental" />
			<label for="student_name" class="form-label fw-bold">
				<%= __('form.name') %>
			</label>
			<input
				type="text"
				name="student_name"
				id="student_name"
				class="form-control"
				value="<%= rentalInput.student_name || '' %>"
				required
			/>
		</div>

		<div class="col-md-6">
			<label for="phone" class="form-label fw-bold">
				<%= __('form.phone') %>
			</label>
			<input
				type="tel"
				name="phone"
				id="phone"
				class="form-control"
				value="<%= rentalInput.phone || '' %>"
				required
			/>
		</div>

		<div class="col-md-6">
			<label for="email" class="form-label fw-bold">
				<%= __('form.email') %>
			</label>
			<input
				type="email"
				name="email"
				id="email"
				class="form-control"
				value="<%= rentalInput.email || '' %>"
			/>
		</div>

		<div class="col-md-6">
			<label for="region" class="form-label fw-bold">
				<%= __('form.region') %>
			</label>
			<select name="region" id="region" class="form-select" required>
				<option value="montreal" <%= rentalInput.region === 'montreal' ? 'selected' : '' %>>
					<%= __('regions.montreal') %>
				</option>
				<option value="laval" <%= rentalInput.region === 'laval' ? 'selected' : '' %>>
					<%= __('regions.laval') %>
				</option>
			</select>
		</div>

		<div class="col-12" data-montreal-payment-summary>
			<div class="alert alert-info small mb-0" role="status">
				<strong><%= __('payment.montreal_price_label', 'Montreal fixed price') %>:</strong>
				<%= montrealCarRentalPayment.subtotal %>
				<span class="text-muted">
					(<%= __('payment.gst', 'GST') %> <%= montrealCarRentalPayment.gst %>,
					<%= __('payment.qst', 'QST') %> <%= montrealCarRentalPayment.qst %>)
				</span>
				<strong><%= __('payment.total', 'Total') %>: <%= montrealCarRentalPayment.total %></strong>
			</div>
		</div>

		<div class="col-12" data-montreal-office-info>
			<div class="alert alert-primary small mb-0" role="note">
				<strong><%= __('booking.montreal_exam_arrival_title', 'Important for Montreal SAAQ exam car rental') %>:</strong>
				<%= __('booking.montreal_exam_arrival_notice', 'Please be at our office 40 minutes before your exam. We will take you to the SAAQ exam with the car.') %>
				<span class="d-block mt-1">
					<strong><%= __('booking.office_label', 'Office') %>:</strong>
					<%= officeAddress %>
				</span>
			</div>
		</div>

		<div class="col-md-4">
			<label for="exam_date" class="form-label fw-bold">
				<%= __('form.exam_date') %>
			</label>
			<input
				type="date"
				name="exam_date"
				id="exam_date"
				class="form-control"
				value="<%= rentalInput.exam_date || '' %>"
				required
			/>
		</div>

		<div class="col-md-4">
			<label for="exam_time" class="form-label fw-bold">
				<%= __('form.exam_time') %>
			</label>
			<input
				type="time"
				name="exam_time"
				id="exam_time"
				class="form-control"
				value="<%= rentalInput.exam_time || '' %>"
			/>
		</div>

		<div class="col-md-4">
			<label for="preferred_language" class="form-label fw-bold">
				<%= __('form.preferred_language') %>
			</label>
			<select
				name="preferred_language"
				id="preferred_language"
				class="form-select"
			>
				<option value="en" <%= rentalInput.preferred_language === 'en' ? 'selected' : '' %>>English</option>
				<option value="fr" <%= rentalInput.preferred_language === 'fr' ? 'selected' : '' %>>Français</option>
				<option value="ar" <%= rentalInput.preferred_language === 'ar' ? 'selected' : '' %>>العربية</option>
				<option value="es" <%= rentalInput.preferred_language === 'es' ? 'selected' : '' %>>Español</option>
				<option value="de" <%= rentalInput.preferred_language === 'de' ? 'selected' : '' %>>Deutsch</option>
			</select>
		</div>

		<div class="col-12">
			<label for="notes" class="form-label fw-bold">
				<%= __('form.notes') %>
			</label>
			<textarea
				name="notes"
				id="notes"
				class="form-control"
				rows="3"
			><%= rentalInput.notes || '' %></textarea>
		</div>
	</div>

	<input type="hidden" name="service_type" value="car_rental" />

	<div class="alert alert-warning small mt-4" role="alert">
		<%- __('booking.disclaimer') %>
	</div>

	<div class="text-center mb-4">
		<button
			type="submit"
			class="btn btn-primary mt-3"
			name="payment_provider"
			value="stripe"
			data-region-submit-button
			data-payment-label="<%= __('payment.pay_with_stripe', 'Pay with card / wallet') %>"
			data-submit-label="<%= __('form.submit') %>"
		>
			<i class="bi bi-credit-card me-1" data-submit-icon></i>
			<span data-submit-label-text><%= __('payment.pay_with_stripe', 'Pay with card / wallet') %></span>
		</button>

		<button
			type="submit"
			class="btn btn-dark mt-3 ms-sm-2"
			name="payment_provider"
			value="paypal"
			data-paypal-submit-button
		>
			<i class="bi bi-paypal me-1"></i>
			<span><%= __('payment.pay_with_paypal', 'Pay with PayPal') %></span>
		</button>
	</div>
</form>

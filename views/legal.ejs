<!-- views/legal.ejs -->
<section class="legal-page">
	<div class="container">
		<div class="legal-document mx-auto">
			<p class="legal-updated mb-2"><%= __('legal.last_updated', 'Last updated') %>: <%= page.updated %></p>
			<h1><%= page.title %></h1>
			<p class="legal-intro"><%= page.intro %></p>

			<% page.sections.forEach(section => { %>
				<section class="legal-section">
					<h2><%= section.heading %></h2>
					<% section.body.forEach(paragraph => { %>
						<p><%= paragraph %></p>
					<% }) %>
				</section>
			<% }) %>
		</div>
	</div>
</section>
